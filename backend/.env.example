PORT=5000
NODE_ENV=development

# Database
# Use a Neon PostgreSQL connection string: postgresql://[user]:[password]@[host]/[dbname]?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_interviewer?sslmode=disable

# JWT Secrets
JWT_SECRET=your_super_secret_access_token_key_12345
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_67890

# AI API Keys
GROQ_API_KEY=your_groq_api_key_here
